{
    "semi": false,
    "tabWidth": 4,
    "printWidth": 120,
    "quoteProps": "consistent",
    "overrides": [
        {
            "files": "src/Stage/*/*.ts",
            "options": {
                "singleAttributePerLine": true,
                "bracketSameLine": true,
                "printWidth": 400
            }
        }
    ]
}
